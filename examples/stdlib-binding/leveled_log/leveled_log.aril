// Leveled logging with a prefix over the `log` package. Exercises
// `log.setFlags`, `log.setPrefix`, `log.println`, `log.printf`
// (binding-surface.md §log). `log` writes to stderr, so correctness is the
// exit code, not a stdout diff.
import log

func main() {
  log.setFlags(0)                // drop the date/time prefix — deterministic output
  log.setPrefix("[svc] ")
  log.println("starting up")
  log.printf("listening on port %d", 8080)
}

// CounterStack Pentix agent — a self-contained Aril port of the architecture
// from the `counterstack-champion` project. Pentix is Tetris with pentominoes,
// driven by a server over a JSON wire protocol.
//
// The original talks to a 500 Hz server over JSON Lines on TCP. Here the
// server is an in-process goroutine and the "wire" is a pair of channels
// carrying discrete JSON messages (one envelope per channel element, which
// subsumes the newline framing TCP needed) — so the example is self-contained
// and runnable while keeping the three load-bearing pieces intact:
//
//   1. **Wire protocol** — sum-typed `Inbound`/`Outbound` with real
//      `encoding/json` encode/decode through a flat envelope DTO; the server's
//      string `t` discriminator is lifted to an exhaustive `match`.
//   2. **Concurrent transport** — a reader spawn decodes inbound into `inbox`,
//      a writer spawn encodes `outbox` back onto the wire; they share the
//      channels with the decision loop running inline in the scope body.
//   3. **Game loop** — a `class implements Strategy` decides one action per
//      `Tick`; the loop terminates cleanly on `MatchEnd`.
//
// A monitor goroutine owns stdout: every actor logs events as they happen, so
// the output interleaves the server's and agent's lines. The run-check asserts
// the agent's protocol milestones appear in order (`expected_patterns`) and
// that no decode error / zero-score finish occurs (`forbidden_patterns`).

import fmt
import json
import strconv

// Inbound envelopes the agent reacts to (the subset the loop consumes).
type Inbound =
  | Hello(server: string, version: int)
  | Tick(tickNo: int, current: string)
  | Ping(nonce: int)
  | MatchEnd(score: int, rank: int)

// Outbound envelopes the agent emits.
type Outbound =
  | Ready(config: string)
  | Action(op: string)
  | Pong(nonce: int)

let protocolVersion = 5

// Flat JSON envelope: a `t` discriminator plus every field any kind needs
// (unused fields default to zero/empty on serialize). One parse narrows it —
// no `json.RawMessage` two-pass.
type Wire = {
  t:       string
  server:  string
  version: int
  tickNo:  int
  current: string
  nonce:   int
  score:   int
  rank:    int
  op:      string
  config:  string
}

func encodeInbound(i: Inbound): Result<[]byte, error> {
  let w = match i {
    Hello(s, v)      => Wire{ t: "hello", server: s, version: v },
    Tick(no, cur)    => Wire{ t: "tick", tickNo: no, current: cur },
    Ping(n)          => Wire{ t: "ping", nonce: n },
    MatchEnd(sc, rk) => Wire{ t: "match_end", score: sc, rank: rk },
  }
  return json.serialize(w)
}

func encodeOutbound(o: Outbound): Result<[]byte, error> {
  let w = match o {
    Ready(cfg) => Wire{ t: "ready", config: cfg },
    Action(op) => Wire{ t: "action", op: op },
    Pong(n)    => Wire{ t: "pong", nonce: n },
  }
  return json.serialize(w)
}

// Decode one wire message into the typed Inbound. A malformed kind is an
// Err(error) rather than a panic, so a single bad message fails the run loudly.
func decodeInbound(msg: []byte): Result<Inbound, error> {
  let w = try json.parse<Wire>(msg)
  match w.t {
    "hello"     => Ok(Hello(w.server, w.version)),
    "tick"      => Ok(Tick(w.tickNo, w.current)),
    "ping"      => Ok(Ping(w.nonce)),
    "match_end" => Ok(MatchEnd(w.score, w.rank)),
    _           => Err(error("unknown envelope kind: " + w.t)),
  }
}

interface Strategy {
  decide(current: string): string
}

// A trivial strategy configured with the move it always plays. Real strategies
// would decide on the piece + board; this one ignores them.
class FixedMove implements Strategy {
  let op: string

  decide(current: string): string {
    return op
  }
}

// The in-process server: scripts a short match onto the wire, then reads the
// agent's actions back. Stands in for the TCP server.
func server(toAgent: SendChan<[]byte>, fromAgent: RecvChan<[]byte>, log: SendChan<string>):
    Result<unit, error> {
  let script = [
    Hello("pentix-server", protocolVersion),
    Tick(1, "I"),
    Tick(2, "T"),
    Ping(42),
    Tick(3, "L"),
    MatchEnd(120, 3),
  ]
  for env in script {
    let msg = try encodeInbound(env)
    toAgent.send(msg)
  }
  toAgent.close()

  // Read whatever the agent sent back, logging each opcode.
  for actBytes in fromAgent {
    let w = try json.parse<Wire>(actBytes)
    log.send("server <- " + w.t)
  }
  return Ok(())
}

func main() {
  let toAgent   = makeChannel<[]byte>(16)
  let fromAgent = makeChannel<[]byte>(16)
  let inbox     = makeChannel<Inbound>(16)
  let outbox    = makeChannel<Outbound>(16)
  let log       = makeChannel<string>(64)
  let strat     = FixedMove{ op: "drop" }

  match scope<unit, error> {
    // Monitor: owns stdout, prints log lines as they arrive.
    spawn {
      for line in log {
        fmt.println(line)
      }
      return Ok(())
    }

    // Coordinator: runs the server + agent transport in an inner scope, then
    // closes `log` once both have joined so the monitor (and outer scope) end.
    spawn {
      var finalScore = 0
      try scope<unit, error> {
        // The server.
        spawn {
          match server(toAgent, fromAgent, log) {
            Ok(_)  => {},
            Err(e) => return Err(e),
          }
          return Ok(())
        }

        // Reader: decode the wire into `inbox`, closing it at EOF so the
        // decision loop's `for env in inbox` can exit if no MatchEnd arrives.
        spawn {
          defer inbox.close()
          for msg in toAgent {
            match decodeInbound(msg) {
              Ok(env) => inbox.send(env),
              Err(e)  => return Err(e),
            }
          }
          return Ok(())
        }

        // Writer: encode `outbox` back onto the wire; close the agent->server
        // direction when the decision loop is done so the server's read loop
        // terminates.
        spawn {
          for o in outbox {
            let msg = try encodeOutbound(o)
            fromAgent.send(msg)
          }
          fromAgent.close()
          return Ok(())
        }

        // Decision loop: owns every `outbox` send and closes it at the end
        // (closing earlier would race the sends). A spawn so the inner scope
        // body is all-spawns; it writes `finalScore`, read after the scope
        // joins.
        spawn {
          outbox.send(Ready("pentris-7"))
          log.send("agent -> ready (pentris-7)")
          for env in inbox {
            match env {
              Hello(s, v) => {
                log.send("agent <- hello from " + s + " v" + strconv.itoa(v))
              },
              Ping(n) => {
                outbox.send(Pong(n))
                log.send("agent -> pong " + strconv.itoa(n))
              },
              Tick(no, cur) => {
                outbox.send(Action(strat.decide(cur)))
                log.send("agent -> action drop @tick " + strconv.itoa(no))
              },
              MatchEnd(sc, rk) => {
                log.send("agent <- match_end score=" + strconv.itoa(sc) + " rank=" + strconv.itoa(rk))
                finalScore = sc
                break
              },
            }
          }
          outbox.close()
          return Ok(())
        }
      }
      log.send("agent: final score " + strconv.itoa(finalScore))
      log.close()
      return Ok(())
    }
  } {
    Ok(_)  => {},
    Err(e) => fmt.println("agent error:", e),
  }
}

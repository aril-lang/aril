// Number each line read from stdin — exercising the `bufio.Scanner` value
// handle (`bufio.newScanner(os.stdin)` + the `scan`/`text` method set) and the
// `os.stdin` standard-input stream. See docs/binding-surface.md §bufio.
import fmt
import bufio
import os

func main() {
  let sc = bufio.newScanner(os.stdin)
  var n = 0
  while sc.scan() {
    n = n + 1
    fmt.println(n, sc.text())
  }
}

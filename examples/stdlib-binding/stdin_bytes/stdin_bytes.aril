// DEMAND SKETCH (build-fails until `io` + `os.stdin` bind) — slurp all of stdin
// through an io.Reader and report the byte count. Forces `io.readAll(os.stdin):
// Result<[]byte, error>` (binding-surface.md §io) + the `os.stdin` std stream.
import fmt
import io
import os
import strconv

func main() {
  match io.readAll(os.stdin) {
    Ok(data) => fmt.println("bytes: " + strconv.itoa(data.len())),
    Err(e)   => fmt.println("read error:", e),
  }
}
